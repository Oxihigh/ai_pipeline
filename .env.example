# ==============================================================================
# ESCROW CALL TRANSCRIPT AI PROCESSING PIPELINE - CONFIGURATION TEMPLATE
# ==============================================================================

# --- Oracle Database Configuration ---
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_HOST=your_oracle_host.example.com
DB_PORT=1521
DB_SERVICE_NAME=your_oracle_service_name
DB_QUERY=SELECT INTAC_UUID FROM call_records WHERE classification = 'Escrow'

# --- AWS Configuration ---
# AWS Credentials are automatically detected if run on an EC2 instance with an IAM Role.
# For local testing, configure these if needed:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
AWS_REGION=us-east-1

# PrivateLink VPC Endpoints (Optional: configure if corporate security blocks public AWS endpoints)
# S3_ENDPOINT_URL=https://bucket.vpce-xxxxxx.s3.us-east-1.vpce.amazonaws.com
# BEDROCK_ENDPOINT_URL=https://bedrock.vpce-xxxxxx.us-east-1.vpce.amazonaws.com

# --- S3 Bucket & Folders ---
S3_BUCKET_NAME=your-escrow-processing-bucket
S3_SOURCE_PREFIX=transcripts/           # Folder where transcript text files reside
S3_INPUT_PREFIX=bedrock-input/          # Folder where generated JSONL batches will be uploaded
S3_OUTPUT_PREFIX=bedrock-output/        # Folder where Bedrock will write output files

# --- Bedrock Batch Inference Config ---
# IAM Role ARN that Amazon Bedrock assumes to read/write from/to your S3 bucket.
# This role must trust the Bedrock service principal (bedrock.amazonaws.com)
BEDROCK_ROLE_ARN=arn:aws:iam::123456789012:role/BedrockBatchInferenceS3AccessRole
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# --- Pipeline Behavior Config ---
# Parallel fetching from S3
MAX_S3_WORKERS=50

# S3 Download chunk size (limits memory usage during processing)
BATCH_CHUNK_SIZE=1000

# Bedrock limits: Max 50,000 records or 100MB per batch file.
# Keeping these conservative for safety.
BEDROCK_MAX_RECORDS_PER_FILE=45000
BEDROCK_MAX_MB_PER_FILE=90

# Output Paths
LOCAL_MASTER_CSV_PATH=output/master_consolidated.csv
LOCAL_STATE_DB_PATH=pipeline.db
PROMPT_TEMPLATE_PATH=prompt_template.txt
