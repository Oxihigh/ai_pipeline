# ==============================================================================
# ESCROW CALL TRANSCRIPT AI PROCESSING PIPELINE - CONFIGURATION TEMPLATE
# ==============================================================================

# --- Oracle Database Configuration ---
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_HOST=your_oracle_host.example.com
DB_PORT=1521
DB_SERVICE_NAME=your_oracle_service_name

# Target database query retrieving loan numbers and comments
DB_QUERY="WITH escrow_call_loans AS (
    SELECT A2.LOAN_NUM As LOAN_NUMBER,
           MAX(A2.CALL_DT) AS LATEST_ESCROW_CALL_DT
    FROM SRVNG.CALL_MSTR A2
    JOIN SRVNG.CALL_AI_INTNT A1
      ON A2.INTAC_UUID = A1.INTAC_UUID
    WHERE A2.CALL_DT >= ADD_MONTHS(TRUNC(SYSDATE, 'MM'), -6)
      AND A2.CALL_DT < TRUNC(SYSDATE, 'MM')
      AND A1.INTNT_CAT_LVL_1 LIKE '%Escrow%'
      AND A2.LOAN_NUM IS NOT NULL
    GROUP BY A2.LOAN_NUM
),
top_1000_loans AS (
    SELECT LOAN_NUMBER
    FROM (
        SELECT LOAN_NUMBER
        FROM escrow_call_loans
        ORDER BY LATEST_ESCROW_CALL_DT DESC
    )
    WHERE ROWNUM <= 1000
),
latest_escrow_uuids AS (
    SELECT A2.LOAN_NUM AS LOAN_NUMBER,
           A2.INTAC_UUID,
           A2.CALL_DT
    FROM SRVNG.CALL_MSTR A2
    JOIN SRVNG.CALL_AI_INTNT A1 ON A2.INTAC_UUID = A1.INTAC_UUID
    WHERE A1.INTNT_CAT_LVL_1 LIKE '%Escrow%'
)
SELECT DISTINCT
    e.LOAN_NUMBER,
    e.LATEST_ESCROW_CALL_DT,
    u.INTAC_UUID,
    c.LONG_COMMENT_CODE,
    c.LONG_COMMENT_DATE,
    c.LONG_COMMENT_USER_ID,
    TRIM(
        TRIM(NVL(c.LONG_COMMENT_TEXT_LINE_01, '')) || ' ' ||
        TRIM(NVL(c.LONG_COMMENT_TEXT_LINE_02, '')) || ' ' ||
        TRIM(NVL(c.LONG_COMMENT_TEXT_LINE_03, '')) || ' ' ||
        TRIM(NVL(c.LONG_COMMENT_TEXT_LINE_04, '')) || ' ' ||
        TRIM(NVL(c.LONG_COMMENT_TEXT_LINE_05, '')) || ' ' ||
        TRIM(NVL(c.LONG_COMMENT_TEXT_LINE_06, ''))
    ) AS FULL_COMMENT,
    c.ACTV_FLG AS COMMENT_ACTV_FLG
FROM escrow_call_loans e
JOIN top_1000_loans t ON t.LOAN_NUMBER = e.LOAN_NUMBER
JOIN latest_escrow_uuids u ON u.LOAN_NUMBER = e.LOAN_NUMBER AND u.CALL_DT = e.LATEST_ESCROW_CALL_DT
JOIN \"BDE\".\"LONG_COMMENT\" c ON c.LOAN_NUMBER = e.LOAN_NUMBER
ORDER BY e.LOAN_NUMBER,
         c.LONG_COMMENT_DATE DESC"

# --- AWS Configuration ---
# AWS Credentials are automatically detected if run on an EC2 instance with an IAM Role.
# For local testing, configure these if needed:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
REGION=us-east-1

# --- S3 Configuration ---
S3_BUCKET=opex-onity
INPUT_PREFIX=input/
OUTPUT_PREFIX=output/

# --- VPC S3 Endpoint & Source Transcripts ---
# Set the full S3 source URL to automatically extract the S3 endpoint URL, source bucket, and source prefix:
S3_SOURCE_URL=http://vpce-0ac65af589dffda12-87nib9i5.s3.us-east-1.vpce.amazonaws.com/livevox-rpa/processed_transcripts/TXT

# Or configure them manually:
# S3_ENDPOINT_URL=
# S3_SOURCE_BUCKET_NAME=
# S3_SOURCE_PREFIX=

# --- Bedrock Configuration ---
# IAM Role ARN that Amazon Bedrock assumes to read/write from/to your S3 bucket.
# This role must trust the Bedrock service principal (bedrock.amazonaws.com)
ROLE_ARN=arn:aws:iam::991706071148:role/opex_onity_bedrock_batch_inference_role
MODEL_ID=arn:aws:bedrock:us-east-1:991706071148:inference-profile/us.anthropic.claude-sonnet-4-6

# --- Pipeline Behavior Config ---
# Parallel fetching from S3
MAX_S3_WORKERS=50

# S3 Download chunk size (limits memory usage during processing)
BATCH_CHUNK_SIZE=1000

# Bedrock limits: Max 50,000 records or 100MB per batch file.
# Keeping these conservative for safety.
BEDROCK_MAX_RECORDS_PER_FILE=45000
BEDROCK_MAX_MB_PER_FILE=90

# Output Paths
LOCAL_MASTER_CSV_PATH=output/master_consolidated.csv
LOCAL_STATE_DB_PATH=pipeline.db
PROMPT_TEMPLATE_PATH=prompt_template.txt
